# Example environment variables
# Copy this to .env and fill in your values

# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=123456789012345678

# OpenClaw Gateway (leave empty to read from ~/.openclaw/openclaw.json)
OPENCLAW_GATEWAY_URL=ws://localhost:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_SESSION_KEY=main
OPENCLAW_TRANSPORT=gateway   # gateway or cli
OPENCLAW_CLI_PATH=openclaw

# STT Configuration
STT_BACKEND=openai  # or 'local'
OPENAI_API_KEY=your_openai_api_key_here  # required if using OpenAI STT

# TTS Configuration
TTS_BACKEND=edge   # or 'elevenlabs'
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here  # required if using ElevenLabs TTS
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # optional, default is Rachel

# Language (for TTS)
LANGUAGE=ro  # Romanian, or 'en' for English, 'fr' for French, etc.

# Whisper Local Model (optional, for local STT)
# WHISPER_MODEL_PATH=./models/ggml-base.bin
