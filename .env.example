# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=ws://localhost:18789
OPENCLAW_GATEWAY_TOKEN=

# STT Configuration
STT_BACKEND=local  # or 'openai'
OPENAI_API_KEY=    # Required if using OpenAI STT

# TTS Configuration
TTS_BACKEND=edge   # or 'elevenlabs'
ELEVENLABS_API_KEY= # Required if using ElevenLabs TTS

# Language
LANGUAGE=ro        # Romanian, or 'en' for English

# Whisper Local Model (optional)
WHISPER_MODEL_PATH=./models/ggml-base.bin